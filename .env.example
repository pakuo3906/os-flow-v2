APP_ENV=development
# APP_RUN_MODE can be api, notification-worker, notification-report,
# notification-line-webhook-report, or notification-line-webhook-alerts.
APP_RUN_MODE=api
DATABASE_PATH=data/app.db
STORAGE_ROOT=storage
OUTPUT_ROOT=output
TEMP_ROOT=temp
RAG_ROOT=storage/rag

INSFORGE_BASE_URL=
# Required for the future InsForge repository adapter.
INSFORGE_PROJECT_ID=
INSFORGE_API_KEY=
INSFORGE_DATABASE_URL=
# Required for the future InsForge storage adapter.
INSFORGE_STORAGE_BUCKET=
INSFORGE_STORAGE_NAMESPACE=
INSFORGE_AUTH_JWKS_URL=
INSFORGE_AUTH_ISSUER_URL=
INSFORGE_AUTH_AUDIENCE=
INSFORGE_MCP_BASE_URL=

# Optional customer scoping placeholders for future multi-tenant auth.
CUSTOMER_DEFAULT_SLUG=
CUSTOMER_DEFAULT_NAME=

DISCORD_BOT_TOKEN=
DISCORD_TARGET_CHANNEL_IDS=123456789012345678

AI_PROVIDER=openai_compatible
AI_API_KEY=
AI_MODEL=gpt-4.1
AI_BASE_URL=https://api.openai.com/v1

NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_USERNAME=
NOTIFICATION_WEBHOOK_AVATAR_URL=
NOTIFICATION_SLACK_WEBHOOK_URL=
NOTIFICATION_LINE_API_BASE_URL=https://api.line.me
NOTIFICATION_LINE_CHANNEL_ACCESS_TOKEN=
NOTIFICATION_LINE_RECIPIENT_IDS=
NOTIFICATION_AUTO_URGENT_TARGETS=line,discord
NOTIFICATION_AUTO_WARNING_TARGETS=slack,email

NOTIFICATION_EMAIL_SMTP_HOST=
NOTIFICATION_EMAIL_SMTP_PORT=587
NOTIFICATION_EMAIL_SMTP_USERNAME=
NOTIFICATION_EMAIL_SMTP_PASSWORD=
NOTIFICATION_EMAIL_USE_TLS=true
NOTIFICATION_EMAIL_FROM=
NOTIFICATION_EMAIL_RECIPIENTS=
NOTIFICATION_EMAIL_SUBJECT_PREFIX=O's flow
